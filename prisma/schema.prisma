generator client {
  provider      = "prisma-client-js"
  // "native" para desarrollo local (Windows/Mac); el segundo target es el motor
  // que necesita la imagen Docker (node:20-alpine, musl + OpenSSL 3.x).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subjects      Subject[]
  studySessions StudySession[]
  goals         Goal[]
  reminders     Reminder[]

  @@map("users")
}

model Subject {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   Assignment[]
  studySessions StudySession[]
  goals         Goal[]

  @@index([userId])
  @@map("subjects")
}

model Assignment {
  id          String           @id @default(uuid())
  subjectId   String
  title       String
  description String?
  dueDate     DateTime
  status      AssignmentStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studySessions StudySession[]
  reminders     Reminder[]

  @@index([subjectId])
  @@index([dueDate])
  @@map("assignments")
}

model StudySession {
  id              String   @id @default(uuid())
  userId          String
  subjectId       String
  assignmentId    String?
  startedAt       DateTime
  durationMinutes Int
  notes           String?
  createdAt       DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subjectId])
  @@index([startedAt])
  @@map("study_sessions")
}

model Goal {
  id          String     @id @default(uuid())
  userId      String
  subjectId   String?
  title       String
  description String?
  targetDate  DateTime?
  progress    Int        @default(0)
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject?   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  reminders Reminder[]

  @@index([userId])
  @@map("goals")
}

// Un reminder pertenece a un assignment O a un goal (nunca ambos ni ninguno).
// Prisma no soporta relaciones polimórficas nativas: esa regla se valida en la
// capa de servicio (ver src/services/reminder.service.ts), no en el schema.
model Reminder {
  id           String   @id @default(uuid())
  userId       String
  assignmentId String?
  goalId       String?
  remindAt     DateTime
  message      String
  sent         Boolean  @default(false)
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  goal       Goal?       @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([remindAt])
  @@map("reminders")
}
